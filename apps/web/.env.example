# Auth0 Configuration
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Database
DATABASE_URL=

# Stripe API Keys and Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs - Server-side (webhook processing)
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_LIFETIME=

# Stripe Price IDs - Client-side (frontend billing page)
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=

# Daemon Authentication
# Secret token para o daemon autenticar ao enviar decisões para a API web
CONTEXT_KEEPER_TOKEN=

# SEO
NEXT_PUBLIC_SITE_URL=https://contextkeeper.dev

# Optional
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
