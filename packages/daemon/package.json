{
  "name": "@jeanzorzetti/context-keeper",
  "version": "1.0.0",
  "description": "Context Keeper daemon — watches Claude Code transcripts, extracts decisions via Groq, updates CLAUDE.md",
  "main": "dist/index.js",
  "bin": {
    "context-keeper": "dist/cli.js"
  },
  "publishConfig": {
